# ─── Jovi AI — Environment Template ──────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it contains secrets.
# NEVER put real secrets in this file — it is committed to git.
# ──────────────────────────────────────────────────────────

# ─── Telegram ─────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated Telegram user IDs allowed to talk to the bot.
# Find yours by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=123456789

# God Mode allows unrestricted capabilities, infinite loops bypass, and ignores safe output limits
GOD_MODE=true

# ─── LLM ──────────────────────────────────────────────────
# OpenRouter API key (starts with sk-or-)
OPENROUTER_API_KEY=sk-or-your-key-here

# Model to use via OpenRouter (optional)
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ─── Voice ────────────────────────────────────────────────
# Groq API key for Whisper transcription
GROQ_API_KEY=gsk_your-groq-key-here

# ElevenLabs API key for TTS
ELEVENLABS_API_KEY=your-elevenlabs-key-here
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
# ELEVENLABS_MODEL=eleven_multilingual_v2

# ─── Memory ───────────────────────────────────────────────
# SQLite path (optional, default: jovi_memory.db)
# DB_PATH=jovi_memory.db

# Qdrant for semantic long-term memory
QDRANT_URL=your-qdrant-url-here
QDRANT_API_KEY=your-qdrant-api-key-here
# QDRANT_COLLECTION=gravity-claw

# OpenAI for embeddings (optional if not using semantic memory)
# OPENAI_API_KEY=your-openai-key-here

# ─── MCP Server Secrets ───────────────────────────────────
# GitHub Personal Access Token (used by the GitHub MCP server)
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat-here

# Supabase access token (used by the Supabase MCP server)
SUPABASE_ACCESS_TOKEN=your-supabase-access-token-here

# ─── Remote Control (PC Agent) ────────────────────────────
# Shared secret for authenticating the PC agent (required to enable remote control)
REMOTE_CONTROL_SECRET=your-secure-random-secret-here

# URL for the remote agent to connect to (set on PC, NOT on Railway)
# For Railway: wss://your-app.railway.app
# For local dev: ws://localhost:3001
REMOTE_CONTROL_URL=ws://localhost:3001

# Port for the relay server (optional — Railway auto-assigns $PORT)
# REMOTE_CONTROL_PORT=3001

# ─── Logging ──────────────────────────────────────────────
# Log level: debug | info | warn | error (optional, default: info)
# LOG_LEVEL=info

# ─── Google Sheets (To-Do List) ───────────────────────────
# Base64-encoded Service Account JSON file text (required for WRITE access via OAuth2)
GOOGLE_SERVICE_ACCOUNT_B64=base64-encoded-string-here
