    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Jovi Claw] Running: $CLAUDE_TOOL_INPUT_COMMAND'",
