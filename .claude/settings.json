            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"Add-Type -AssemblyName System.Windows.Forms; [System.Windows.Forms.MessageBox]::Show('Jovi Claw: Claude done. Ready, Boss.', 'Claude Code', 'OK', 'Information')\"",
            "timeout": 10
          }
        ]
      }
    ]
